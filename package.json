{
	"name": "agent-browser-bridge",
	"type": "module",
    "version": "1.0.0",
	"private": true,
	"workspaces": [
		"logger",
		"protocol",
		"bridge",
		"chrome-extension"
	],
	"scripts": {
		"mcp": "bun bridge/src/mcp/server.ts",
		"start": "bun bridge/src/mcp/server.ts",
		"dev": "bun --watch bridge/src/mcp/server.ts",
		"ws": "bun index.ts",
		"build:ext": "bun run --filter @agent-browser-bridge/chrome-extension build",
		"dev:ext": "bun run --filter @agent-browser-bridge/chrome-extension dev",
		"typecheck": "bun run --filter '*' typecheck",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"fix": "biome check --write .",
		"check": "bun run typecheck && bun run lint && bun run test",
		"test": "bun test protocol bridge",
		"test:watch": "bun test --watch protocol bridge",
		"test:vitest": "vitest run",
		"test:vitest:watch": "vitest",
		"test:mutation": "bun run --filter @agent-browser-bridge/chrome-extension test:mutation",
		"test:mutation:dry": "bun run --filter @agent-browser-bridge/chrome-extension test:mutation:dry",
		"benchmark": "bun run --filter @agent-browser-bridge/bridge benchmark"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@agent-browser-bridge/logger": "workspace:*",
		"@stryker-mutator/core": "^9.6.1",
		"@stryker-mutator/vitest-runner": "^9.6.1",
		"@types/bun": "^1.3.13",
		"@types/chrome": "^0.1.40",
		"@vitest/coverage-v8": "^4.1.5",
		"@vitest/runner": "^4.1.5",
		"happy-dom": "^20.9.0",
		"vitest": "^4.1.5"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	}
}
