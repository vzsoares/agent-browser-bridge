{
	"manifest_version": 3,
	"name": "Agent Browser Bridge",
	"version": "0.1.0",
	"description": "Bridge between a coding agent (via MCP) and the browser, enabling browser automation from any MCP-compatible client.",
	"permissions": ["activeTab", "scripting", "storage", "tabs"],
	"host_permissions": ["<all_urls>"],
	"background": {
		"service_worker": "src/background/background.ts"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["src/content/index.ts"]
		}
	],
	"action": {
		"default_popup": "src/popup/index.html"
	}
}
